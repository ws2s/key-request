@page "/"

<PageTitle>Keys/Access - University of Virginia Facilities Management - Customer Portal</PageTitle>
<script>
    (async function() {
        const { text } = await (await fetch(`/api/data`)).json();
        document.querySelector('#name').textContent = text;
    }());
</script>
<div class="keys-container">
    <div class="linkBoxes">
        <p>
            The key request form has changed and is accessible below. If you have any questions please see the Key Request Overview training document on the <a href="https://www.fm.virginia.edu/services/lock.html" target="_blank">Lock Shop site</a> or contact the Customer Support Center.
        </p>
        <div class="heading-left">
            <h1 class="orange-line-right">Keys/Electronic Access</h1>
        </div>
        <div class="icon-cards">
            <div class="icon-card">
                <a href="https://customerportal.fm.virginia.edu/keyrequest/residential">
                    <div class="icon-card-inner">
                        <div class="icon-card-image-container">
                            <div class="icon-card-image icon-recycle-bin">
                                <img src="https://customerportal.fm.virginia.edu/Home/images/layout/residential-lockout_icon.svg" alt="Residential key icon">
                            </div>
                        </div>
                        <div class="icon-card-copy">
                            <h2 class="icon-card-title">
                                Residential lockout/<br>
                                lost key
                            </h2>
                        </div>
                    </div>
                </a>
            </div>

            <div class="icon-card">
                <a href="https://customerportal.fm.virginia.edu/keyrequest/requestor">
                    <div class="icon-card-inner">
                        <div class="icon-card-image-container">
                            <div class="icon-card-image icon-list-check">
                                <img src="https://customerportal.fm.virginia.edu/Home/images/layout/access-space_icon.svg" alt="Key to an opened door icon">
                            </div>
                        </div>
                        <div class="icon-card-copy">
                            <h2 class="icon-card-title">Key requests</h2>
                            <p class="icon-card-description">Order keys, transfer keys, request rekey, etc.</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="icon-card">
                <a href="https://customerportal.fm.virginia.edu/keyrequest/keyreview/1">
                    <div class="icon-card-inner">
                        <div class="icon-card-image-container">
                            <div class="icon-card-image icon-list-check">
                                <img src="https://customerportal.fm.virginia.edu/Home/images/layout/reuse_checklist-icon.svg" alt="Checklist on a clipboard">
                            </div>
                        </div>
                        <div class="icon-card-copy">
                            <h2 class="icon-card-title">Review key requests</h2>
                            <p class="icon-card-description">View, update, print your key requests, etc.</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="icon-card">
                <a href="https://customerportal.fm.virginia.edu/keyrequest/non-residential">
                    <div class="icon-card-inner">
                        <div class="icon-card-image-container">
                            <div class="icon-card-image icon-list-eye">
                                <img src="https://customerportal.fm.virginia.edu/Home/images/layout/non-residential-lockout_icon.svg" alt="Non-residential key icon">
                            </div>
                        </div>
                        <div class="icon-card-copy">
                            <h2 class="icon-card-title">
                                Non-residential lockout/<br>
                                lost key
                            </h2>
                            <p class="icon-card-description">Office lockouts, etc.</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="icon-card">
                <a href="https://customerportal.fm.virginia.edu/Customerrequest/request/report">
                    <div class="icon-card-inner">
                        <div class="icon-card-image-container">
                            <div class="icon-card-image icon-recycle-green">
                                <img src="https://customerportal.fm.virginia.edu/Home/images/layout/auxiliary-key_icon.svg" alt="Recycle icon">
                            </div>
                        </div>
                        <div class="icon-card-copy">
                            <h2 class="icon-card-title">Non-door keys</h2>
                            <p class="icon-card-description">Filing cabinets, desks, mail boxes, padlocks, etc.</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="icon-card">
                <a href="https://customerportal.fm.virginia.edu/customerrequest/request/electronicaccess">
                    <div class="icon-card-inner">
                        <div class="icon-card-image-container">
                            <div class="icon-card-image icon-list-check">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
                                    <path d="M184 32C197.3 32 208 42.7 208 56L208 112L160 112L160 56C160 42.7 170.7 32 184 32zM456 352C442.7 352 432 341.3 432 328L432 56C432 42.7 442.7 32 456 32C469.3 32 480 42.7 480 56L480 328C480 341.3 469.3 352 456 352zM384 48L384 132.1C374.3 125.4 363.6 120.1 352 116.7L352 48C352 39.2 359.2 32 368 32C376.8 32 384 39.2 384 48zM320 64L320 112L256 112L256 64C256 46.3 270.3 32 288 32C305.7 32 320 46.3 320 64zM512 64C512 46.3 526.3 32 544 32C561.7 32 576 46.3 576 64L576 320C576 337.7 561.7 352 544 352C526.3 352 512 337.7 512 320L512 64zM64 224C64 188.7 92.7 160 128 160L320 160C355.3 160 384 188.7 384 224L384 512C384 547.3 355.3 576 320 576L128 576C92.7 576 64 547.3 64 512L64 224zM136 396L136 420C136 426.6 141.4 432 148 432L188 432C194.6 432 200 426.6 200 420L200 396C200 389.4 194.6 384 188 384L148 384C141.4 384 136 389.4 136 396zM152 224C138.7 224 128 234.7 128 248L128 296C128 309.3 138.7 320 152 320L296 320C309.3 320 320 309.3 320 296L320 248C320 234.7 309.3 224 296 224L152 224zM136 476L136 500C136 506.6 141.4 512 148 512L188 512C194.6 512 200 506.6 200 500L200 476C200 469.4 194.6 464 188 464L148 464C141.4 464 136 469.4 136 476zM260 384C253.4 384 248 389.4 248 396L248 420C248 426.6 253.4 432 260 432L300 432C306.6 432 312 426.6 312 420L312 396C312 389.4 306.6 384 300 384L260 384zM248 476L248 500C248 506.6 253.4 512 260 512L300 512C306.6 512 312 506.6 312 500L312 476C312 469.4 306.6 464 300 464L260 464C253.4 464 248 469.4 248 476z" />
                                </svg>
                            </div>
                        </div>
                        <div class="icon-card-copy">
                            <h2 class="icon-card-title">Access control hardware</h2>
                            <p class="icon-card-description">Estimate for installation of new electronic access</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="icon-card">
                <a href="https://idoffice.virginia.edu/mobile-id-wallet">
                    <div class="icon-card-inner">
                        <div class="icon-card-image-container">
                            <div class="icon-card-image icon-list-check">
                                <img src="https://customerportal.fm.virginia.edu/Home/images/layout/uva-rotunda-logo_blue.png" alt="Graphic llustration of UVA Rotunda in University Blue">
                            </div>
                        </div>
                        <div class="icon-card-copy">
                            <h2 class="icon-card-title">Cavalier Card Office</h2>
                            <p class="icon-card-description">ID information and contact details</p>
                        </div>
                    </div>
                </a>
            </div>

        </div>
    </div>
</div>
